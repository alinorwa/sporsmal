<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-GLhlTQ8iRABdZLl6O3oVMWSktQOp6b7In1Zl3/Jr59b6EGGoI1aFkw7cmDA6j6gD"
      crossorigin="anonymous"
    />
    <link rel="shortcut icon" href="/img/ali.png" type="image/png" />
    <title>spørsmålet</title>
  </head>
  <body class="bg-dark">
    <div class="container">
      <div class="row">
        <div class="col-lg-12">
          <div class="mb-5">
            <h3 class="" style="margin-top: 130px !important">
              <% if (data) { %>
              <h1 class="text-center text-white"><%= data.spør %></h1>
              <div class="text-center mt-5">
                <button onclick="reloadPage()" class="btn btn-outline-info">
                  endre spørsmålet
                </button>
              </div>
              <% } else { %>
              <p>No Ask found</p>
              <% } %>
            </h3>
          </div>
        </div>
        <div class="col-lg-12">
          <!-- start text form  -->
          <div class="mt-5">
            <form>
              <p class="text-capitalize fw-bold text-info-emphasis">
                " Vær så snill , gi meg svaret ditt med enten ja eller nei hvis
                du vil lære norsk "
              </p>
              <div class="">
                <textarea
                  id="floatingInput"
                  class="form-control bg-black text-white"
                  name=""
                  id=""
                  cols="20"
                  rows="6"
                  required
                ></textarea>
              </div>
              <div class="d-grid gap-2 mt-3">
                <button type="submit" class="btn btn-outline-info">
                  svar på spørsmålene
                </button>
              </div>
            </form>
          </div>
          <!-- end text form  -->
        </div>
      </div>
    </div>

    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN"
      crossorigin="anonymous"
    ></script>
    <script>
      function reloadPage() {
        window.location.reload();
      }
    </script>
  </body>
</html>
